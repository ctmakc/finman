        "@capacitor/core": "^8.0.2",
        "@capacitor/ios": "^8.0.2",
        "@google/generative-ai": "^0.24.1",
        "axios": "^1.4.0",
        "bcrypt": "^5.1.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dompurify": "^3.3.3",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "express-session": "^1.17.3",
        "express-validator": "^7.3.1",
        "helmet": "^8.1.0",
